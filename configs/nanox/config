[ui]
hint_bar=true
warning_lamp=true
warning_format=[WARN]
error_format=[ERR!]
help_key=F1
help_language=en

[edit]
soft_tab=true
soft_tab_width=4
autocomplete=true
use_lsp=false
cold_storage_timeout=30

[search]
case_sensitive_default=false

[ai]
# Enable AI Copilot completions. Requires Ollama running locally or remotely.
enabled=false
# Ollama model name (e.g. qwen2.5-coder:1.5b, deepseek-coder:1.3b)
model=qwen2.5-coder:1.5b
# API endpoint for code generation
endpoint=http://localhost:11434/api/generate
# Generation sampling temperature (0.0 to 1.0)
temperature=0.2

